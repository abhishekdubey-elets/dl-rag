# =============================================================================
# digitalLEARNING RAG API — environment configuration
# Copy to `.env` and adjust. All values have sensible defaults for local dev.
# =============================================================================

# --- Application ---
APP_NAME="digitalLEARNING RAG API"
ENVIRONMENT=development            # development | staging | production
DEBUG=true
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false                     # true → JSON logs (use in prod)

# --- Server ---
HOST=0.0.0.0
PORT=8000
WORKERS=1

# --- API surface ---
SERVE_UI=true                      # false → API-only (no demo chat page at "/")
CORS_ORIGINS=                      # comma-separated browser origins allowed to call the API

# --- Security ---
# Comma-separated API keys accepted in the `X-API-Key` header.
API_KEYS=dev-local-key
REQUIRE_AUTH=false                 # set true in staging/production
RATE_LIMIT_REQUESTS=60             # requests per window per API key/IP
RATE_LIMIT_WINDOW_SECONDS=60

# --- PostgreSQL ---
POSTGRES_DSN=postgresql+asyncpg://dl:dl@localhost:5432/dl_rag

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=dl_chunks

# --- Embeddings (Sentence Transformers) ---
# bge-small (384d, fast) for dev; bge-large-en-v1.5 (1024d) for best quality.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DEVICE=cpu               # cpu | cuda
EMBEDDING_BATCH_SIZE=32
EMBEDDING_QUERY_PREFIX="Represent this sentence for searching relevant passages: "

# --- Cross-encoder reranker ---
# Dev: cross-encoder/ms-marco-MiniLM-L-6-v2 ; Prod: BAAI/bge-reranker-large
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_DEVICE=cpu

# --- Retrieval pipeline ---
RETRIEVAL_CANDIDATES=40            # candidates before rerank
FINAL_TOP_K=8                      # chunks passed to the LLM
RRF_K=60                           # reciprocal-rank-fusion constant
VECTOR_WEIGHT=1.0
SPARSE_WEIGHT=1.0
KG_EXPANSION_ENABLED=true
MIN_RERANK_SCORE=-1000000.0    # raw CE logits are often negative; floor disabled by default
CONTEXT_MAX_TOKENS=6000            # compression budget for final context

# --- LLM (OpenAI-compatible interface) ---
# Works with OpenAI, Azure OpenAI, vLLM, Together, Groq, Ollama, etc.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-replace-me
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1500
LLM_TIMEOUT_SECONDS=60

# --- Crawler ---
CRAWLER_BASE_URL=https://digitallearning.eletsonline.com
CRAWLER_USER_AGENT="dLEARNING-RAG-Indexer/0.1 (+https://digitallearning.in)"
CRAWLER_CONCURRENCY=4
CRAWLER_DELAY_SECONDS=1.0          # politeness delay between requests per worker
CRAWLER_RESPECT_ROBOTS=true
CRAWLER_MAX_PAGES=0                # 0 = unlimited
CRAWLER_TIMEOUT_SECONDS=30

# --- YouTube ingestion ---
YOUTUBE_CHANNEL_URL=https://www.youtube.com/user/eletsvideos
# Optional Google YouTube Data API v3 key (catalog). Keyless yt-dlp is used when unset.
YOUTUBE_API_KEY=
# Optional keyed transcript service: URL template with {video_id}; key sent in the header below.
# Keyless youtube-transcript-api is used when unset (and as fallback).
TRANSCRIPT_API_URL=
TRANSCRIPT_API_KEY=
TRANSCRIPT_API_KEY_HEADER=x-api-key
TRANSCRIPT_LANGUAGES=en,en-IN,en-GB,hi
YOUTUBE_MAX_VIDEOS=500

# --- Chunking ---
CHUNK_MAX_TOKENS=600
CHUNK_OVERLAP_RATIO=0.15
CHUNK_MIN_TOKENS=64

# --- Conversation memory ---
MEMORY_MAX_TURNS=20               # verbatim turns kept before summarization
MEMORY_TTL_SECONDS=604800         # 7 days

# --- Caching ---
CACHE_TTL_SECONDS=3600
ANSWER_CACHE_ENABLED=true
EMBEDDING_CACHE_ENABLED=true
